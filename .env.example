# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Conexion directa a Postgres para Drizzle (Project Settings > Database > Connection string)
DATABASE_URL=

# Secreto del cron de generacion diaria. Vercel lo manda como
# "Authorization: Bearer <CRON_SECRET>" al endpoint /api/cron/generar-dia.
# Pon cualquier cadena larga y aleatoria. En local puedes dejarlo vacio.
CRON_SECRET=
